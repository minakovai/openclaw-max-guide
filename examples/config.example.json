{
  "_comment": "Пример конфигурации OpenClaw с MAX интеграцией. Замените placeholder'ы на реальные значения.",
  "env": {
    "MAX_BOT_TOKEN": "YOUR_MAX_BOT_TOKEN_HERE"
  },
  "channels": {
    "max": {
      "enabled": true,
      "token": "${MAX_BOT_TOKEN}",
      "dmPolicy": "allowlist",
      "allowFrom": ["YOUR_MAX_USER_ID"]
    }
  }
}
